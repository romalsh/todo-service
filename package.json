{
	"name": "todo-service",
	"version": "1.0.0",
	"description": "Backend for a mobile To-Do application (NestJS, REST, JWT)",
	"license": "MIT",
	"scripts": {
		"build": "nest build",
		"start": "node dist/src/main",
		"dev": "nest start --watch",
		"typeorm": "typeorm-ts-node-commonjs -d db/data-source.ts",
		"migration:generate": "npm run typeorm -- migration:generate db/migrations/Migration",
		"migration:create": "typeorm-ts-node-commonjs migration:create db/migrations/Migration",
		"migration:run": "npm run typeorm -- migration:run",
		"migration:revert": "npm run typeorm -- migration:revert",
		"migration:show": "npm run typeorm -- migration:show",
		"test": "jest --runInBand",
		"test:unit": "jest --testPathPattern=\"src/|libs/\" --runInBand",
		"test:e2e": "jest -c jest-e2e.config.js --runInBand --forceExit"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.4",
		"@nestjs/config": "^3.2.3",
		"@nestjs/core": "^10.4.4",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/passport": "^10.0.3",
		"@nestjs/platform-express": "^10.4.4",
		"@nestjs/platform-socket.io": "^10.4.4",
		"@nestjs/schedule": "^4.1.1",
		"@nestjs/swagger": "^7.4.2",
		"@nestjs/throttler": "^6.2.1",
		"@nestjs/typeorm": "^10.0.2",
		"@nestjs/websockets": "^10.4.4",
		"bcrypt": "^5.1.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"dotenv": "^16.4.5",
		"helmet": "^7.1.0",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pg": "^8.12.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"socket.io": "^4.8.0",
		"tsconfig-paths": "^4.2.0",
		"typeorm": "^0.3.20"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.5",
		"@nestjs/schematics": "^10.1.4",
		"@nestjs/testing": "^10.4.4",
		"@testcontainers/postgresql": "^10.13.1",
		"@types/bcrypt": "^5.0.2",
		"@types/jest": "^29.5.13",
		"@types/node": "^20.16.10",
		"@types/passport-jwt": "^4.0.1",
		"@types/supertest": "^6.0.2",
		"jest": "^29.7.0",
		"supertest": "^7.0.0",
		"testcontainers": "^10.13.1",
		"ts-jest": "^29.2.5",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.2"
	}
}
