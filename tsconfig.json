{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"ignoreDeprecations": "5.0",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"declaration": false,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["jest", "node"],
		"paths": {
			"@core/*": ["src/core/*"],
			"@module/*": ["src/modules/*"],
			"@libs/common": ["libs/common/src"]
		}
	},
	"include": ["src/**/*", "libs/**/*", "db/**/*", "tests/**/*"]
}
